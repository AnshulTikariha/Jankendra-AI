APP_NAME=Jankendra-AI Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./data/jankendra.db
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
JWT_SECRET_KEY=change-me-in-production-use-a-long-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
