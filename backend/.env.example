APP_NAME=Jankendra-AI Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
EXPOSE_DEMO_OTP=true
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./data/jankendra.db
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
JWT_SECRET_KEY=change-me-in-production-use-a-long-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_JSON_PATH=./data/gcp-service-account.json
DIALOGFLOW_LANGUAGE_CODE=en-IN
GOOGLE_CLOUD_LOCATION=asia-south1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
AI_MODULES_API_URL=http://127.0.0.1:8012
# AI Modules service: uvicorn ai_modules.api.main:app --host 127.0.0.1 --port 8012
