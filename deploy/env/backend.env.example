APP_NAME=Jankendra-AI Backend
APP_VERSION=0.1.0
ENVIRONMENT=production
EXPOSE_DEMO_OTP=true
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:////opt/jankendra/backend/data/jankendra.db
DB_ECHO=false
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=https://jankendra-ai.web.app,https://YOUR_API_DOMAIN
